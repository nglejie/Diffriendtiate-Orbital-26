{
  "name": "diffriendtiate",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @diffriendtiate/server\" \"npm run dev --workspace @diffriendtiate/client\"",
    "client": "npm run dev --workspace @diffriendtiate/client",
    "server": "npm run dev --workspace @diffriendtiate/server",
    "build": "npm run build --workspace @diffriendtiate/client",
    "preview": "npm run preview --workspace @diffriendtiate/client",
    "start": "npm run start --workspace @diffriendtiate/server",
    "check": "npm run check --workspace @diffriendtiate/server && npm run build --workspace @diffriendtiate/client",
    "test:build": "node tests/scripts/build-reproducibility.mjs",
    "qa": "npm run check && npm test",
    "test": "npm run test:build && npm run test:unit && npm run test:integration && npm run test:ai && npm run test:performance && npm run test:security && npm run test:e2e",
    "test:unit": "vitest run --config tests/vitest.config.mjs tests/unit tests/components",
    "test:integration": "vitest run --config tests/vitest.node.config.mjs tests/integration",
    "test:ai": "vitest run --config tests/vitest.node.config.mjs tests/ai",
    "test:performance": "vitest run --config tests/vitest.node.config.mjs tests/performance",
    "test:security": "vitest run --config tests/vitest.node.config.mjs tests/security",
    "test:e2e": "playwright test --config tests/playwright.config.mjs",
    "test:evidence": "node tests/scripts/run-with-evidence.mjs",
    "test:performance:k6": "node tests/performance/run-k6.mjs",
    "test:security:external": "npm run test:security:audit && npm run test:security:zap",
    "test:security:audit": "npm audit --omit=dev --workspaces --audit-level=high",
    "test:security:zap": "node tests/security/run-zap-baseline.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^10.0.1",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
