{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom", "@playwright/test"]
  },
  "include": ["apps/tests/**/*.ts", "apps/tests/**/*.tsx", "apps/tests/**/*.mts", "tests/**/*.ts", "tests/**/*.mts"],
  "exclude": ["docs", "node_modules", "services"]
}
