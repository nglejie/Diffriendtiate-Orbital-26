# Diffriendtiate lite production keeps the core app, API, uploads, and Socket.IO online.
# It intentionally does not run Postgres, Chroma, Ollama, or server-chatbot.

NODE_ENV=production
PORT=4000
APP_TIMEZONE=Asia/Singapore

# Generate real secret values before deploying.
JWT_SECRET=replace-with-a-long-random-secret
LLM_API_KEY_ENCRYPTION_KEY=replace-with-a-32-byte-or-longer-secret

# Empty DATABASE_URL makes the server use persistent JSON storage.
DATABASE_URL=
DIFFRIENDTIATE_DATA_DIR=/opt/diffriendtiate/shared/data

# Intelligrate chatbot is separate from this lite target.
CHATBOT_BASE_URL=
INTELLIGRATE_GPU_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_MODEL=models/gemini-embedding-2
USE_GEMINI_EMBEDDINGS=false

# Supabase Auth. Leave empty for local server auth.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# OAuth callbacks should use the deployed public URL when configured.
OAUTH_PUBLIC_BASE_URL=http://replace-with-public-host
OAUTH_CLIENT_REDIRECT_URL=http://replace-with-public-host
MICROSOFT_OAUTH_PUBLIC_BASE_URL=http://replace-with-public-host
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_TENANT_ID=organizations
MICROSOFT_ALLOWED_EMAIL_DOMAINS=nus.edu.sg,u.nus.edu

# Real email delivery is required for email verification and password reset.
AUTH_DEV_ACTION_LINKS=false
AUTH_DEV_RESET_LINKS=false
AUTH_MAILBOX_URL=
AUTH_EMAIL_FROM="Diffriendtiate <no-reply@example.com>"
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
