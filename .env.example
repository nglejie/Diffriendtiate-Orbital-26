# Main Application
APP_PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
POSTGRES_DB=diffriendtiate
POSTGRES_USER=diffriendtiate
POSTGRES_PASSWORD=replace-with-a-strong-password
CHATBOT_BASE_URL=http://server-chatbot:5000
NODE_BASE_URL=http://server:4000

# Supabase Auth
# When these are set, the onboarding UI uses Supabase for email/password,
# verification emails, password reset, and OAuth. The server still owns
# Diffriendtiate domain/profile data and verifies Supabase access tokens.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# OAuth login providers
# Register callbacks as:
# http://127.0.0.1:4000/api/auth/oauth/google/callback
# http://127.0.0.1:4000/api/auth/oauth/github/callback
# Microsoft Entra web redirect URIs require localhost for HTTP loopback:
# http://localhost:4000/api/auth/oauth/microsoft/callback
OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:4000
OAUTH_CLIENT_REDIRECT_URL=http://127.0.0.1:4000
MICROSOFT_OAUTH_PUBLIC_BASE_URL=http://localhost:4000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_TENANT_ID=organizations
MICROSOFT_ALLOWED_EMAIL_DOMAINS=nus.edu.sg,u.nus.edu
# For a personal Microsoft fallback app, use:
# MICROSOFT_TENANT_ID=common
# MICROSOFT_ALLOWED_EMAIL_DOMAINS=*
AUTH_DEV_ACTION_LINKS=false
AUTH_DEV_RESET_LINKS=false
AUTH_MAILBOX_URL=http://127.0.0.1:8025

# Real email delivery for password reset and email verification.
# Registration, email verification, and password reset require SMTP unless
# AUTH_DEV_ACTION_LINKS is explicitly enabled for isolated tests.
# Docker local development includes Mailpit at http://127.0.0.1:8025.
AUTH_EMAIL_FROM="Diffriendtiate <no-reply@example.com>"
SMTP_URL=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# Server-Chatbot
CHROMA_DIR=/app/chroma_db

## Chatbot gemini stuff
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-3.1-flash-lite # gemini-2.5-flash / gemini-3.5-flash # (using gemeni-3.1-flash-lite as high usage limit per day can use but low usage rate limit) | is default if no model model provided
GEMINI_EMBED_MODEL=models/gemini-embedding-2
USE_GEMINI_EMBEDDINGS=false
SEARCH_MIN_RELEVANCE=0.35 # used to judge retrieved source usage

## Chatbot Log File
CHATBOT_LOG_FILE=/app/logs/chatbot.log # if not set, log file is not saved anywhere

## DEBUG
PYTHONUNBUFFERED=1 # To see print statements live in logs

# Ollama Service (Only used if using Ollama)
OLLAMA_BASE_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5:7b # can use qwen2.5:3b for faster inference, trying 7b for better tooling performance