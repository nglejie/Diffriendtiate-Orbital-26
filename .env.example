# Main Application
APP_PORT=4000
JWT_SECRET=replace-with-a-long-random-secret
POSTGRES_DB=diffriendtiate
POSTGRES_USER=diffriendtiate
POSTGRES_PASSWORD=replace-with-a-strong-password
CHATBOT_BASE_URL=http://server-chatbot:5000
NODE_BASE_URL=http://server:4000

# Server-Chatbot
CHROMA_DIR=/app/chroma_db

# Ollama Service
OLLAMA_BASE_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5:7b # can use qwen2.5:3b for faster inference, trying 7b for better tooling performance
SEARCH_MIN_RELEVANCE=0.35 # used to judge retrieved source usage